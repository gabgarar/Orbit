      "sky_atmosphere": true,
      "globe_lighting": true,
      "stars_enabled": true
    },
    "recording": {
      "quality": "high",
      "output_format": "mp4"
    }
  },
  "data": {
    "satellites_catalog_file": "catalog.json"
