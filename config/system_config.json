{
  "system": {
    "orbit": {
      "propagation_hours": 0.5,
      "future_show": true,
      "ground_track_show": false,
      "future_line_width": 2,
      "width_mode": "visual",
      "future_color": "#7fd7ff",
      "selected_color": "#ff2d2d",
      "past_show": true,
      "past_color": "#ff9a5a",
      "past_seconds": 120,
      "past_line_width": 2
    },
    "satellites": {
      "label_size_px": 10,
      "model_scale": 1,
      "use_3d_model": true,
      "size_mode": "visual",
      "max_visible": 100
    },
    "realtime": {
      "state_interval_seconds": 1,
      "orbit_interval_seconds": 1
    },
    "logging": {
      "enabled": true,
      "level": "info",
      "show_top_clock": true
    },
    "rendering": {
      "antialias_mode": "off",
      "antialias_enabled": true,
      "background_color": "#03070d",
      "sky_atmosphere": false,
      "globe_lighting": true,
      "stars_enabled": false
    },
    "recording": {
      "quality": "medium",
      "output_format": "webm"
    },
    "ui": {
      "language": "en",
      "theme": "dark"
    }
  },
  "data": {
    "satellites_catalog_file": "catalog.json"
  }
}
